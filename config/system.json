{
    "system": {
        "name": "排弹抢修指挥系统",
        "version": "1.0.0",
        "language": "zh_CN",
        "theme": "dark"
    },
    "server": {
        "dataProcessing": {
            "host": "localhost",
            "port": 9090
        },
        "dataStorage": {
            "host": "localhost",
            "port": 5432
        }
    },
    "communication": {
        "mqtt": {
            "broker": "localhost",
            "port": 1883,
            "username": "",
            "password": ""
        },
        "websocket": {
            "port": 8080
        }
    },
    "map": {
        "defaultZoom": 15,
        "center": {
            "longitude": 108.9321,
            "latitude": 34.2345
        },
        "maxBounds": {
            "minLon": 108.0,
            "maxLon": 110.0,
            "minLat": 33.0,
            "maxLat": 35.0
        }
    },
    "detection": {
        "autoStart": false,
        "defaultAltitude": 50,
        "scanSpeed": 10
    },
    "logging": {
        "level": "info",
        "file": "./logs/app.log",
        "maxSize": 10485760,
        "maxFiles": 10
    }
